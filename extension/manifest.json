{
  "manifest_version": 3,
  "name": "Capsule — AI-Powered PR Analyzer",
  "version": "1.0.0",
  "description": "Analyzes GitHub PRs against your BRD, detects workflow impacts, and previews release changelogs.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://github.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Capsule Summary"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
