# API Access Security Key (Required for Chrome Extension authentication)
API_KEY=capsule_super_secure_api_key_123

# GitHub Credentials (Required for pulling diffs and pushing changelog)
# Personal Access Token must have 'repo' scopes
GITHUB_TOKEN=ghp_yourPersonalAccessTokenHere
# Webhook secret for HMAC signature validation of incoming GitHub Webhooks
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here

# Release Target Repository (Where changelog.txt is pushed)
# Format: owner/repository-name (e.g. facebook/react)
CHANGELOG_REPO=owner/release-changelog-repository

# NVIDIA NIM Configuration (NVIDIA LLM API details)
NVIDIA_NIM_API_KEY=nvapi-yourNvidiaNimApiKeyHere
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=meta/llama-3.1-70b-instruct

# Jenkins Configuration
# Token used to invoke Jenkins generic webhooks
JENKINS_API_TOKEN=your_jenkins_api_token_here

# SQLite Database Connection URL
DATABASE_URL=sqlite+aiosqlite:///./data/capsule.db

# Path to the Business Requirement Document
BRD_FILE_PATH=./brd/requirements.md

# Log Level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
